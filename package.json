{
  "name": "horse-legal-guide-velocity",
  "version": "1.0.0",
  "private": true,
  "description": "Velocity artifact repo for Horse Legal Guide",
  "license": "UNLICENSED",
  "scripts": {
    "validate:preflight": "node _ops/validators/validate_preflight.js",
    "validate:mode": "node _ops/validators/validate_mode.js",
    "validate:review": "node _ops/validators/validate_review_flow.js",
    "validate:content": "node _ops/validators/validate_page_contract.js",
    "validate:links": "node _ops/validators/validate_internal_links.js",
    "validate:ingestion": "node _ops/validators/validate_ingestion.js",
    "validate:distribution": "node _ops/validators/validate_distribution.js",
    "validate:policy": "node _ops/validators/validate_policy_compliance.js",
    "validate:canonical": "node _ops/validators/validate_canonical_protection.js",
    "validate:disclaimers": "node _ops/validators/validate_disclaimer_presence.js",
    "validate:footer": "node _ops/validators/validate_footer_links.js",
    "validate:manual": "node _ops/validators/validate_manual_mode.js",
    "validate:all": "npm run build && npm run validate:mode && npm run validate:review && npm run validate:content && npm run validate:answer-shape && npm run validate:above-fold && npm run validate:extractability && npm run validate:links && npm run validate:ingestion && npm run validate:distribution && npm run validate:policy && npm run validate:canonical && npm run validate:disclaimers && npm run validate:footer && npm run validate:manual && npm run validate:content-system && npm run validate:publish_quality && npm run validate:editorial && npm run validate:public-surfaces && npm run validate:answer-surface-monitoring && npm run validate:page-manifests && npm run validate:recommendation-workflow && npm run validate:family-scaffold && npm run validate:compare-contract && npm run validate:scenario-contract && npm run validate:faq-opening",
    "build": "node scripts/build/build_site.js",
    "publish:mode": "node scripts/publishing/run_mode_pipeline.js",
    "collect:signals": "node scripts/community/collect_signals.js",
    "package:baseline": "node scripts/build/package_baseline.js",
    "generate:drafts": "node scripts/build/generate_drafts.js",
    "validate:content-system": "node _ops/validators/validate_content_system.js",
    "validate:drafts": "node _ops/validators/validate_draft_quality.js",
    "validate:publish_quality": "node _ops/validators/validate_publish_quality.js",
    "approve:one": "node scripts/admin/approve_one.js",
    "approve:type": "node scripts/admin/approve_by_type.js",
    "approve:filter": "node scripts/admin/approve_by_filter.js",
    "reject:one": "node scripts/admin/reject_one.js",
    "validate:editorial": "node _ops/validators/validate_editorial_system.js",
    "validate:public-surfaces": "node _ops/validators/validate_public_surfaces.js",
    "normalize:signals": "node scripts/community/normalize_signals.js",
    "map:signals": "node scripts/community/map_signals_to_targets.js",
    "report:ingestion": "node scripts/community/generate_ingestion_report.js",
    "ingest:manual": "npm run collect:signals && npm run normalize:signals && npm run map:signals && npm run report:ingestion",
    "validate:query-traceability": "node _ops/validators/validate_query_traceability.js",
    "validate:entity-coverage": "node _ops/validators/validate_entity_coverage.js",
    "validate:authority-graph": "node _ops/validators/validate_internal_authority_graph.js",
    "validate:canonical-contract": "node _ops/validators/validate_canonical_url_contract.js",
    "validate:crawl-contract": "node _ops/validators/validate_crawl_contract.js",
    "validate:sitemap-parity": "node _ops/validators/validate_sitemap_page_parity.js",
    "validate:foundation:audit": "node _ops/validators/run_all_validators.js --mode=audit",
    "validate:foundation:enforce": "node _ops/validators/run_all_validators.js --mode=enforce",
    "validate:answer-shape": "node _ops/validators/validate_answer_shape.js",
    "validate:above-fold": "node _ops/validators/validate_above_fold.js",
    "validate:extractability": "node _ops/validators/validate_extractability.js",
    "validate:pre-render-contract": "node scripts/build/validate_page_contract_pre_render.js",
    "validate:post-render-contract": "node scripts/build/validate_page_contract_post_render.js",
    "monitor:answer-surface": "node scripts/monitoring/generate_answer_surface_reports.js",
    "validate:answer-surface-monitoring": "node _ops/validators/validate_answer_surface_monitoring.js",
    "build:distribution": "node scripts/build/prepare_distribution_artifacts.js",
    "state:refresh": "node -e \"const fs=require('fs');const p='data/content_refresh_state.json';const x=JSON.parse(fs.readFileSync(p,'utf8'));x.last_refresh_started_at=new Date().toISOString();x.last_refresh_status='running';fs.writeFileSync(p,JSON.stringify(x,null,2)+'\\n')\"",
    "state:publish": "node -e \"const fs=require('fs');const p='data/publish_state.json';const x=JSON.parse(fs.readFileSync(p,'utf8'));x.last_publish_attempted_at=new Date().toISOString();x.last_publish_status='running';fs.writeFileSync(p,JSON.stringify(x,null,2)+'\\n')\"",
    "validate:page-manifests": "node _ops/validators/validate_page_manifests.js",
    "patch:validate-page": "node scripts/patch/validate_page_patch.js",
    "patch:apply-page": "node scripts/patch/apply_page_patch.js",
    "patch:apply-system": "node scripts/patch/apply_system_patch.js",
    "recommendations:process": "node scripts/recommendations/process_recommendations.js",
    "validate:recommendation-workflow": "node _ops/validators/validate_recommendation_workflow.js",
    "validate:family-scaffold": "node _ops/validators/validate_family_scaffold_reuse.js",
    "validate:compare-contract": "node _ops/validators/validate_compare_family_contract.js",
    "validate:scenario-contract": "node _ops/validators/validate_scenario_family_contract.js",
    "validate:faq-opening": "node _ops/validators/validate_faq_opening_contract.js"
  }
}
